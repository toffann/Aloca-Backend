# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (sesuaikan dengan docker-compose.yml) ────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=aloca_user
DB_PASSWORD=aloca_password_123
DB_NAME=aloca_management_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_secret_yang_panjang_dan_acak
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Ganti dengan URL frontend saat production, misal: http://localhost:5173
CORS_ORIGIN=*
